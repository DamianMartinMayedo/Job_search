# Neon PostgreSQL
DATABASE_URL=postgres://user:password@host/database

# Auth (simple login, single user)
AUTH_EMAIL=damianmartinmayedo@gmail.com
AUTH_PASSWORD=123456

# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-string

# Google Places API (Text Search — New)
VITE_GOOGLE_PLACES_API_KEY=

# Netlify site URL (for local dev, keep http://localhost:8888)
URL=http://localhost:8888

# SMTP (Gmail — usa una contraseña de aplicación)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuemail@gmail.com
SMTP_PASS=tu-app-password-de-16-caracteres

# IMAP (Gmail) — para ingesta de ofertas por email (LinkedIn, InfoJobs, etc.)
# Puede reusar el mismo app password del SMTP. IMAP_FOLDER apunta al label
# de Gmail donde caen las alertas (crea uno y filtros para no leer el INBOX).
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=tuemail@gmail.com
IMAP_APP_PASSWORD=tu-app-password-de-16-caracteres
IMAP_FOLDER=Ofertas-CRM
